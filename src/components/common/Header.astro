---
// src/components/common/Header.astro
---

<header class="w-full px-6 py-6 md:px-12 flex justify-between items-center text-[#1A1B1C] bg-white">
  
  <a href="/" class="flex items-baseline gap-2">
    <span class="text-2xl font-bold tracking-widest uppercase">KNARQ</span>
    <span class="text-sm font-light tracking-wide text-gray-500 hidden md:block">Arquitectos</span>
  </a>

  <div class="flex items-center gap-8">
    <nav class="hidden md:flex gap-8 text-sm font-light">
      <a href="#" class="hover:text-gray-400 transition-colors">Proyectos</a>
      <a href="#" class="hover:text-gray-400 transition-colors">Despacho</a>
      <a href="#" class="hover:text-gray-400 transition-colors">Contacto</a>
    </nav>

    <button aria-label="Abrir menú" class="focus:outline-none md:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
</header>