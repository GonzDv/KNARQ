---
import projects from '../../data/project.json';
---
<main class="relative w-full h-dvh bg-white flex flex-col">
  <div class="group flex-1 relative w-full h-full">
    
    {projects.map((project, index) => (
      <div 
        class={`slide absolute inset-0 flex flex-col transition-opacity duration-1000 ease-in-out ${
          index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'
        }`}
        data-index={index}
      >
        <div class="w-full h-full md:h-[75vh] px-0 md:px-12 flex flex-col items-center justify-start md:justify-center max-w-400 mx-auto">
          
          <div class="w-full flex justify-center mb-6 md:mb-10 h-[65vh] md:h-[75vh] pt-15 md:pt-20">
              <a href={`/proyectos/${project.slug}`} class="w-full h-full object-cover drop-shadow-none md:drop-shadow-2xl select-none [-webkit-touch-callout:none] pointer-events-none">
            <img 
              src={project.images.hero} 
              alt={`Fotografía de ${project.title}`} 
              class="w-full h-full object-cover md:object-contain drop-shadow-none md:drop-shadow-2xl"
              loading={index === 0 ? "eager" : "lazy"}
              draggable="false"
            />
            </a>
          </div>

          <section class="flex flex-col items-center text-center px-6 md:px-0">
            <h1 class="text-3xl md:text-5xl font-light text-[#1A1B1C] mb-5 md:mb-6 tracking-tight">
              {project.title}
            </h1>
            <a 
              href={`/proyectos/${project.slug}`} 
              class="px-8 py-3 border border-[#1A1B1C] rounded-full text-xs font-medium tracking-widest text-[#1A1B1C] uppercase hover:bg-[#1A1B1C] hover:text-white transition-colors duration-300 pointer-events-auto"
            >
              Ver Obra
            </a>
          </section>

        </div>
      </div>
    ))}

    <button id="prevBtn" class="absolute left-4 top-[40%] md:top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-black/10 text-black hover:bg-black hover:text-white transition-all duration-300 bg-white/50 backdrop-blur-sm z-50 md:left-8 opacity-40 active:opacity-100 md:opacity-0 md:group-hover:opacity-100">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
    </button>
    
    <button id="nextBtn" class="absolute right-4 top-[40%] md:top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-black/10 text-black hover:bg-black hover:text-white transition-all duration-300 bg-white/50 backdrop-blur-sm z-50 md:right-8 opacity-40 active:opacity-100 md:opacity-0 md:group-hover:opacity-100">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
    </button>

  </div>
</main>
<script>
    // En Astro, los scripts se ejecutan en el navegador del cliente automáticamente
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.slide');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    let currentIndex = 0;

    // Función principal para cambiar de diapositiva
    function goToSlide(index = 0) {
      // Lógica de bucle: si pasas del último, vuelve al primero y viceversa
      if (index < 0) index = slides.length - 1;
      if (index >= slides.length) index = 0;

      // Actualizamos las clases CSS de cada slide
      slides.forEach((slide, i) => {
        if (i === index) {
          // Slide Activo: Se hace visible y capta los clics
          slide.classList.remove('opacity-0', 'z-0', 'pointer-events-none');
          slide.classList.add('opacity-100', 'z-10');
        } else {
          // Slides Inactivos: Se ocultan y se vuelven "fantasmas" a los clics
          slide.classList.remove('opacity-100', 'z-10');
          slide.classList.add('opacity-0', 'z-0', 'pointer-events-none');
        }
      });

      currentIndex = index;
    }

    // Event Listeners para los botones
    prevBtn?.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => goToSlide(currentIndex + 1));

    setInterval(() => {
      goToSlide(currentIndex + 1);
    }, 10000);
  });
</script>