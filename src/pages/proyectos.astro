---
import Layout from '../layouts/Layout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

import projects from '../data/project.json';
---

<Layout title="Proyectos | KNARQ_"
  description={project.description}
  image={project.images.hero}>
  <Header />

  <main class="w-full min-h-screen bg-white pb-40 md:pb-48">
    
    <section class="max-w-350 mx-auto px-4 md:px-12 pt-24 md:pt-32">
      <p class="text-xs uppercase tracking-[0.28em] text-gray-400 mb-4">Selección</p>
      <h1 class="gsap-title text-5xl md:text-7xl font-light text-[#1A1B1C] tracking-tight opacity-0 translate-y-8">
        Proyectos
      </h1>
      <p class="gsap-title text-base md:text-lg font-light text-gray-600 max-w-2xl mt-8 opacity-0 translate-y-8 leading-relaxed">
        Una curaduría de espacios residenciales e interiores donde la luz, la materialidad y la proporción construyen la experiencia.
      </p>
    </section>

    <section class="max-w-350 mx-auto px-4 md:px-12 mt-16 md:mt-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-x-8 md:gap-x-12 gap-y-16 md:gap-y-24">
        
        {projects.map((project, index) => {
          const itemNumber = String(index + 1).padStart(2, '0');

          return (
            <a 
              href={`/proyectos/${project.slug}`} 
              class="project-card group block cursor-pointer opacity-0 translate-y-12 md:col-span-6"
            >
              <div class="w-full aspect-4/3 overflow-hidden bg-gray-50">
                <img 
                  src={project.images.hero} 
                  alt={project.title} 
                  class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
                  loading="lazy"
                />
              </div>

              <div class="mt-6 pt-5 border-t border-gray-200 flex justify-between items-start gap-4">
                <div class="flex flex-col">
                  <h2 class="text-2xl md:text-3xl font-light text-[#1A1B1C] transition-colors group-hover:text-gray-500">
                    {project.title}
                  </h2>
                  <p class="text-[10px] md:text-xs uppercase tracking-[0.2em] text-gray-400 mt-2">
                    {project.category}
                  </p>
                </div>
                
                <div class="flex flex-col items-end justify-between h-full min-h-15]">
                  <span class="text-[10px] md:text-xs uppercase tracking-[0.2em] text-gray-300 leading-none">
                    {itemNumber}
                  </span>
                  <span class="text-sm font-bold text-[#1A1B1C] leading-none">
                    {project.details.year}
                  </span>
                </div>
              </div>
            </a>
          );
        })}

      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initProjectsGallery() {
    gsap.registerPlugin(ScrollTrigger);
    ScrollTrigger.getAll().forEach((trigger) => trigger.kill());

    const titles = document.querySelectorAll('.gsap-title');
    if (titles.length > 0) {
      gsap.to(titles, {
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: 'power3.out',
        stagger: 0.15,
      });
    }

    const cards = document.querySelectorAll('.project-card');
    
    cards.forEach((card, index) => {
      gsap.to(card, {
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
          toggleActions: 'play none none reverse'
        },
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: 'power3.out',
        delay: index % 2 === 0 ? 0 : 0.15 
      });
    });
  }

  initProjectsGallery();
  document.addEventListener('astro:page-load', initProjectsGallery);
</script>