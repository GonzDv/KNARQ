---
import Layout from "../layouts/Layout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
---

<Layout title="Contacto | KNARQ">
  <Header />

  <main class="w-full min-h-screen bg-white pb-32">
    <section class="max-w-350 mx-auto px-4 md:px-12 pt-16 md:pt-18">
      <h1
        class="gsap-reveal text-5xl md:text-7xl font-light text-[#1A1B1C] tracking-tight opacity-0 translate-y-8"
      >
        Hablemos de tu <br class="hidden md:block" /> próximo proyecto.
      </h1>
    </section>

    <section class="max-w-350 mx-auto px-4 md:px-12 mt-20 md:mt-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-8">
        <div class="md:col-span-4 flex flex-col gap-12">
          <div class="gsap-reveal opacity-0 translate-y-8">
            <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-6">
              Datos de contacto
            </h2>
            <div class="flex flex-col gap-4">
              <a
                href="mailto:knarq.proyectos@gmail.com"
                class="text-lg font-light hover:text-gray-500 transition-colors"
                >knarq.proyectos@gmail.com</a
              >
              <a
                href="tel:+524425926744"
                class="text-lg font-light hover:text-gray-500 transition-colors"
                >+52 442 592 6744</a
              >
            </div>
          </div>
          {
            /* Información adicional, como dirección de la oficina o redes sociales 
					<div class='gsap-reveal opacity-0 translate-y-8'>
						<h2
							class='text-xs uppercase tracking-[0.3em] text-gray-400 mb-6'
						>
							Oficina
						</h2>
						<p
							class='text-lg font-light leading-relaxed'
						>
							Zapopan, Jalisco.<br />
							México.
						</p>
					</div>
          */
        }
          <div class="gsap-reveal opacity-0 translate-y-8">
            <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-6">
              Social
            </h2>
            <div class="flex gap-6">
              <div class="flex justify-center items-center gap-2">
                <svg
                  fill="#000000"
                  width="24x"
                  height="24px"
                  viewBox="0 0 256 256"
                  id="Flat"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M128,84a44,44,0,1,0,44,44A44.04978,44.04978,0,0,0,128,84Zm0,80a36,36,0,1,1,36-36A36.04061,36.04061,0,0,1,128,164ZM172,32H84A52.059,52.059,0,0,0,32,84v88a52.059,52.059,0,0,0,52,52h88a52.059,52.059,0,0,0,52-52V84A52.059,52.059,0,0,0,172,32Zm44,140a44.04978,44.04978,0,0,1-44,44H84a44.04978,44.04978,0,0,1-44-44V84A44.04978,44.04978,0,0,1,84,40h88a44.04978,44.04978,0,0,1,44,44ZM188,76a8,8,0,1,1-8-8A8.00917,8.00917,0,0,1,188,76Z"
                  ></path>
                </svg>
                <a
                  href="https://www.instagram.com/knarq_/"
                  class="text-sm uppercase tracking-widest hover:underline"
                  >Instagram</a
                >
              </div>
              <div class="flex justify-center items-center gap-2">
                <svg
                  width="24px"
                  height="24px"
                  viewBox="0 0 48 48"
                  xmlns="http://www.w3.org/2000/svg"
                  ><defs
                    ><style>
                      .a,
                      .b {
                        fill: none;
                        stroke: #000000;
                        stroke-linecap: round;
                        stroke-linejoin: round;
                      }
                      .b {
                        stroke-width: 0.8662px;
                      }
                    </style></defs
                  ><path
                    class="a"
                    d="M7.5,5.5a2,2,0,0,0-2,2v33a2,2,0,0,0,2,2h33a2,2,0,0,0,2-2V7.5a2,2,0,0,0-2-2Z"
                  ></path><path
                    class="a"
                    d="M34.0045,29.6513a3.778,3.778,0,0,1-3.2838,1.9072h0a3.7792,3.7792,0,0,1-3.7792-3.7792V25.3227a3.7792,3.7792,0,0,1,3.7792-3.7792h0A3.7792,3.7792,0,0,1,34.5,25.3227V26.551H26.9415"
                  ></path><path
                    class="b"
                    d="M19.7358,24a3.7793,3.7793,0,0,1,0,7.5585H13.5V16.4415h6.2358a3.7793,3.7793,0,0,1,0,7.5585Z"
                  ></path><line class="b" x1="19.7358" y1="24" x2="13.5" y2="24"
                  ></line><line
                    class="a"
                    x1="26.9415"
                    y1="16.4415"
                    x2="34.5"
                    y2="16.4415"></line></svg
                >
                <a
                  href="https://www.behance.net/knarq__"
                  class="text-sm uppercase tracking-widest hover:underline"
                  >Behance</a
                >
              </div>
            </div>
          </div>
        </div>

        <div
          class="md:col-span-7 md:col-start-6 gsap-reveal opacity-0 translate-y-8 relative"
        >
          <form
            id="contactForm"
            class="flex flex-col gap-10 transition-opacity duration-500"
          >
            <div class="relative">
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Nombre completo"
                class="w-full bg-transparent border-b border-gray-200 py-4 outline-none focus:border-[#1A1B1C] transition-colors font-light text-lg placeholder:text-gray-300"
              />
            </div>

            <div class="relative">
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="Correo electrónico"
                class="w-full bg-transparent border-b border-gray-200 py-4 outline-none focus:border-[#1A1B1C] transition-colors font-light text-lg placeholder:text-gray-300"
              />
            </div>
            <div class="relative">
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="Número de teléfono"
                class="w-full bg-transparent border-b border-gray-200 py-4 outline-none focus:border-[#1A1B1C] transition-colors font-light text-lg placeholder:text-gray-300"
              />
            </div>

            <div class="relative">
              <textarea
                id="message"
                name="message"
                required
                rows="4"
                placeholder="Cuéntanos sobre tu proyecto"
                class="w-full bg-transparent border-b border-gray-200 py-4 outline-none focus:border-[#1A1B1C] transition-colors font-light text-lg placeholder:text-gray-300 resize-none"
              ></textarea>
            </div>

            <div class="mt-4">
              <button
                type="submit"
                id="submitBtn"
                class="group flex items-center gap-4 px-10 py-4 border border-[#1A1B1C] rounded-full text-sm font-medium tracking-widest uppercase hover:bg-[#1A1B1C] hover:text-white transition-all duration-500 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span id="btnText">Enviar mensaje</span>
                <svg
                  id="btnIcon"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-4 h-4 transition-transform group-hover:translate-x-2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
                </svg>
              </button>
            </div>
          </form>

          <div
            id="successMessage"
            class="absolute inset-0 flex flex-col justify-center items-start opacity-0 pointer-events-none transition-opacity duration-500"
          >
            <h3 class="text-3xl font-light text-[#1A1B1C] mb-4">
              Mensaje enviado.
            </h3>
            <p class="text-gray-500 font-light leading-relaxed">
              Gracias por tu interés en KNARQ. <br />
              Revisaremos los detalles de tu proyecto y nos pondremos en contacto
              contigo a la brevedad.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";

  function initContactAnimations() {
    const items = document.querySelectorAll(".gsap-reveal");

    if (items.length > 0) {
      gsap.to(items, {
        opacity: 1,
        y: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: "power4.out",
        delay: 0.2,
      });
    }
  }

  initContactAnimations();
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault(); // <--- ESTO ES LO MÁS IMPORTANTE: Detiene el cambio de URL
      e.stopPropagation();

      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const formData = new FormData(form);

      // Cambiamos el texto del botón para saber que el código sí arrancó
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerText = "ENVIANDO...";
      }

      try {
        const response = await fetch('/api/contacto', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          // Si todo sale bien, ocultamos el formulario
          form.classList.add('opacity-0', 'pointer-events-none');
          document.getElementById('successMessage')?.classList.remove('opacity-0');
        } else {
          throw new Error();
        }
      } catch (error) {
        alert('Error al enviar. Revisa la consola del navegador (F12).');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = "REINTENTAR ENVÍO";
        }
      }
    });
  });
</script>
